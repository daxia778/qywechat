# ===== 数据库 =====
DB_PATH=./data/pdd_order.db

# ===== 企业微信 =====
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=0
WECOM_DEFAULT_NOTIFY_IDS=

# 企微客户联系 Secret（需在企微后台「客户联系」功能中获取，与应用Secret不同）
# 若不配置，客户联系相关功能将自动跳过
WECOM_CONTACT_SECRET=

# ===== OCR / AI Vision =====
OCR_PROVIDER=zhipu
ZHIPU_API_KEY=
DASHSCOPE_API_KEY=

# ===== Auth =====
JWT_SECRET_KEY=<run: openssl rand -hex 32>
JWT_EXPIRE_MINUTES=1440

# ===== CORS =====
CORS_ORIGINS=http://localhost:8200

# ===== 服务端口 =====
SERVER_PORT=8201

# ===== 部署模式 =====
# debug: 允许使用默认 JWT 密钥
# production: 强制要求配置高强度 JWT_SECRET_KEY，否则拒绝启动
DEPLOY_MODE=debug

# ===== 派单超时 =====
GRAB_ORDER_TIMEOUT_SECONDS=600

# ===== 分润配置 (百分比 0-100) =====
PLATFORM_FEE_RATE=5          # 平台扣点 (如 PDD 抽佣 5%)
DESIGNER_COMMISSION_RATE=50  # 设计师抽成 50%
OPERATOR_COMMISSION_RATE=10  # 客服提成 10%
# 净利 = 100% - 平台扣点 - 设计师抽成 - 客服提成 = 35%
